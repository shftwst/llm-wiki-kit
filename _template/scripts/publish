#!/usr/bin/env bash
# publish — build a role-filtered, shareable view of the wiki (for Quartz or any site).
#
#   ./scripts/publish <role>            filter the role's pages and build the site with Quartz
#   ./scripts/publish <role> --serve    build and serve a live local preview (localhost:8080)
#   ./scripts/publish <role> --dry-run  report what would be included/excluded; write nothing
#
# A build stages the filtered markdown at .publish/<role>/content/ before building, so that
# content is always available (e.g. for a non-Quartz generator); if git/npm are missing the
# build stops there with instructions instead of installing Quartz.
#
# Roles and the privilege tiers each may see are defined in .publish/roles.tsv. Pages above a
# role's clearance are excluded; links to excluded pages and all ../raw/ citation links are
# de-linked so the published site has no broken links and no paths into private sources.
# index.md and overview.md are skipped (they catalog the whole graph); Quartz builds its own
# navigation. If Quartz is not present it is auto-installed once (git clone + npm i) when git
# and npm are available; the install lives at QUARTZ_DIR (default .publish/quartz, gitignored
# and disposable). Without git/npm the filtered content is staged (the filtering needs no Node).

set -eu
KB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WIKI="$KB_DIR/wiki"
ROLES="$KB_DIR/.publish/roles.tsv"
ROLE="${1:-}"; MODE=build
case "${2:-}" in --dry-run) MODE=dry;; --serve) MODE=serve;; "") ;; *) echo "publish: unknown arg '$2'" >&2; exit 1;; esac

list_roles() { grep -v '^#' "$ROLES" 2>/dev/null | cut -f1 | paste -sd' ' -; }
[ -f "$ROLES" ] || { echo "publish: no .publish/roles.tsv" >&2; exit 1; }
[ -n "$ROLE" ] || { echo "usage: publish <role> [--dry-run|--stage]   (roles: $(list_roles))"; exit 1; }
[ -d "$WIKI" ] || { echo "publish: no wiki/ yet."; exit 0; }

allowed="$(awk -F'\t' -v r="$ROLE" '$1==r{print $2; exit}' "$ROLES")"
[ -n "$allowed" ] || { echo "publish: role '$ROLE' not in roles.tsv (have: $(list_roles))" >&2; exit 1; }
allow_re="^($(printf '%s' "$allowed" | tr -d ' ' | tr ',' '|'))$"
fm_priv() { awk -F': ' '/^privilege:/{print $2; exit}' "$1"; }

inc_file="$(mktemp)"; trap 'rm -f "$inc_file"' EXIT
incn=0; exc=0; pP=0; pB=0; pD=0
for f in $(find "$WIKI" -name '*.md' | sort); do
  base="$(basename "$f" .md)"
  case "$base" in index|overview) continue;; esac     # catalogs; Quartz builds nav
  pv="$(fm_priv "$f")"; pv="${pv:-default}"
  if printf '%s' "$pv" | grep -qE "$allow_re"; then
    printf '%s\n' "$base" >> "$inc_file"; incn=$((incn+1))
    case "$pv" in personal-sensitive) pP=$((pP+1));; business-sensitive) pB=$((pB+1));; *) pD=$((pD+1));; esac
  else
    exc=$((exc+1))
  fi
done

printf 'publish[%s]: clearance = %s\n' "$ROLE" "$allowed"
printf '  include %d (default %d, business %d, personal %d) · exclude %d above clearance\n' "$incn" "$pD" "$pB" "$pP" "$exc"
[ "$MODE" = "dry" ] && { echo "  (dry-run; nothing staged)"; exit 0; }

OUT="$KB_DIR/.publish/$ROLE/content"
rm -rf "$KB_DIR/.publish/$ROLE"; mkdir -p "$OUT"
for f in $(find "$WIKI" -name '*.md' | sort); do
  base="$(basename "$f" .md)"; grep -qxF "$base" "$inc_file" || continue
  rel="${f#"$WIKI"/}"; dest="$OUT/$rel"; mkdir -p "$(dirname "$dest")"
  INC="$inc_file" perl -pe '
    BEGIN { open my $fh,"<",$ENV{INC}; while(<$fh>){chomp; $inc{$_}=1} }
    s{(\[\[([^]|#]+)(?:#[^]|]*)?(?:\|([^]]+))?\]\])}{ exists $inc{$2} ? $1 : ($3 // $2) }ge;  # de-link excluded
    s{\[([^\]]*)\]\(\.\.\/raw\/[^)]*\)}{$1}g;                                                   # de-link raw citations
  ' "$f" > "$dest"
done
printf '  staged → %s\n' "${OUT#"$KB_DIR"/}"

QZ="${QUARTZ_DIR:-$KB_DIR/.publish/quartz}"

# One-off Quartz install if missing. It is disposable (gitignored under .publish/); delete
# the dir to force a fresh clone next run.
if [ ! -f "$QZ/package.json" ]; then
  if command -v git >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
    printf 'publish[%s]: Quartz not found — one-off install into %s (clone + npm i, may take a minute) ...\n' "$ROLE" "${QZ#"$KB_DIR"/}"
    rm -rf "$QZ"
    if git clone --depth 1 https://github.com/jackyzha0/quartz "$QZ" >/dev/null 2>&1 && ( cd "$QZ" && npm i >/dev/null 2>&1 ); then
      echo "  Quartz installed."
    else
      rm -rf "$QZ"   # leave nothing half-built; a re-run retries cleanly
      printf 'publish[%s]: Quartz install failed (network or npm). Content is staged at %s.\n' "$ROLE" "${OUT#"$KB_DIR"/}" >&2
      exit 0
    fi
  else
    printf 'publish[%s]: git and npm are needed to auto-install Quartz. Content staged at %s.\n' "$ROLE" "${OUT#"$KB_DIR"/}" >&2
    echo "  install Node and git, then re-run (or point QUARTZ_DIR at an existing Quartz)."
    exit 0
  fi
fi

# Quartz v5+ generates its plugin barrel (.quartz/) via `plugin install`; a fresh clone
# needs it, else the build fails with: Could not resolve "../../.quartz/plugins".
if [ ! -d "$QZ/.quartz" ]; then
  printf 'publish[%s]: installing Quartz plugins (one-off) ...\n' "$ROLE"
  ( cd "$QZ" && npx quartz plugin install ) || { echo "publish: 'npx quartz plugin install' failed." >&2; exit 1; }
fi

rm -rf "$QZ/content"; cp -R "$OUT" "$QZ/content"
if [ "$MODE" = "serve" ]; then
  printf 'publish[%s]: serving live preview at http://localhost:8080 (Ctrl-C to stop) ...\n' "$ROLE"
  ( cd "$QZ" && npx quartz build --serve )
else
  ( cd "$QZ" && npx quartz build ) && printf 'publish[%s]: built → %s/public\n' "$ROLE" "$QZ"
fi
