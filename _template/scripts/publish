#!/usr/bin/env bash
# publish — build a role-filtered, shareable view of the wiki (for Quartz or any site).
#
#   ./scripts/publish <role>            filter the role's pages and build the site with Quartz
#   ./scripts/publish <role> --serve    build and serve a live local preview (localhost:8080)
#   ./scripts/publish <role> --dry-run  report what would be included/excluded; write nothing
#   ./scripts/publish --all             build every role's site into .publish/sites/<role>/
#   ./scripts/publish --all --dry-run   report include/exclude for every role; write nothing
#
# A build stages the filtered markdown at .publish/<role>/content/ before building, so that
# content is always available (e.g. for a non-Quartz generator); if git/npm are missing the
# build stops there with instructions instead of installing Quartz.
#
# Roles and the privilege tiers each may see are defined in .publish/roles.tsv; the tier and
# page-type vocabularies live in .schema/ (read via scripts/kblib.sh). Pages above a role's
# clearance are excluded; links to excluded pages and all ../raw/ citation links are de-linked
# so the published site has no broken links and no paths into private sources. Pages whose type
# class is `nav` (index, overview) are skipped; a minimal role-view index.md is generated so the
# site root resolves. Quartz builds its own navigation. That landing page leads with a "Most asked
# about" list (the most-queried pages from .ingest/queries.tsv that this role is cleared to see),
# so usage prominence reaches the published site even though overview.md is skipped.
#
# The site title (Quartz's header, and the landing page) is the KB's own title, read from the
# overview's `title:`/H1 (which the ingest infers from the sources), falling back to the
# AGENTS.md H1 then the folder name. Override per build with KB_TITLE=...
#
# One Quartz instance serves one role at a time, so --all writes each role to its own static
# output dir (.publish/sites/<role>/) you can open directly or host; preview one live with
# `publish <role> --serve`. If Quartz is not present it is auto-installed once (git clone +
# npm i) when git and npm are available; the install lives at QUARTZ_DIR (default
# .publish/quartz, gitignored and disposable). Without git/npm the filtered content is still
# staged (the filtering needs no Node).

set -eu
KB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$KB_DIR/scripts/kblib.sh"   # page-type + privilege-tier vocabularies (.schema/)
WIKI="$KB_DIR/wiki"
ROLES="$KB_DIR/.publish/roles.tsv"
QUERIES="$KB_DIR/.ingest/queries.tsv"   # usage log; drives the landing page's "Most asked about"
QZ="${QUARTZ_DIR:-$KB_DIR/.publish/quartz}"

ROLE="${1:-}"; MODE=build; ALL=0
case "$ROLE" in --all|all) ALL=1; ROLE="";; esac
case "${2:-}" in --dry-run) MODE=dry;; --serve) MODE=serve;; "") ;; *) echo "publish: unknown arg '$2'" >&2; exit 1;; esac
if [ "$ALL" = 1 ] && [ "$MODE" = serve ]; then
  echo "publish: --all builds every role's site; it can't serve them all on one port." >&2
  echo "  build them all, then serve one: ./scripts/publish <role> --serve" >&2
  exit 1
fi

list_roles() { grep -v '^#' "$ROLES" 2>/dev/null | cut -f1 | paste -sd' ' -; }
all_roles()  { grep -v '^#' "$ROLES" 2>/dev/null | cut -f1; }
fm_priv() { awk -F': ' '/^privilege:/{print $2; exit}' "$1"; }
fm_type() { awk -F': ' '/^type:/{print $2; exit}' "$1"; }
fm_relev() { awk -F': ' '/^relevance:/{print $2; exit}' "$1"; }

# kb_title: the human title of this KB, inferred by the ingest and read here (publish runs no
# LLM). Resolution order: $KB_TITLE override, then the overview's frontmatter `title:`, then
# its first H1, then the AGENTS.md H1 (minus the schema suffix), then the folder name.
kb_title() {
  [ -n "${KB_TITLE:-}" ] && { printf '%s' "$KB_TITLE"; return; }
  ov="$WIKI/overview.md"
  if [ -f "$ov" ]; then
    t="$(awk -F': ' '/^title:/{sub(/^title: */,"");print;exit}' "$ov")"
    [ -n "$t" ] || t="$(grep -m1 '^# ' "$ov" | sed 's/^# *//')"
    [ -n "$t" ] && { printf '%s' "$t"; return; }
  fi
  if [ -f "$KB_DIR/AGENTS.md" ]; then
    t="$(grep -m1 '^# ' "$KB_DIR/AGENTS.md" | sed 's/^# *//; s/: Knowledge Base Schema.*//')"
    [ -n "$t" ] && { printf '%s' "$t"; return; }
  fi
  basename "$KB_DIR"
}

# quartz_set_title: patch the cloned Quartz's site title so the header stops reading the stock
# "Quartz" default. Strips quotes/backslashes so the title can't break the TS string literal.
quartz_set_title() {
  cfg="$QZ/quartz.config.ts"; [ -f "$cfg" ] || return 0
  T="$(printf '%s' "$1" | tr -d '"\\')" perl -0pi -e 's/pageTitle:\s*"(?:[^"\\]|\\.)*"/pageTitle: "$ENV{T}"/' "$cfg"
}

[ -f "$ROLES" ] || { echo "publish: no .publish/roles.tsv" >&2; exit 1; }
[ "$ALL" = 1 ] || [ -n "$ROLE" ] || { echo "usage: publish <role> [--dry-run|--serve] | publish --all [--dry-run]   (roles: $(list_roles))"; exit 1; }
[ -d "$WIKI" ] || { echo "publish: no wiki/ yet."; exit 0; }
TITLE="$(kb_title)"
DEFAULT_TIER="$(kb_tiers | head -1)"   # lowest-rank tier; the privilege of pages with none set

# stage_role <role> <content-dir>: filter the role's cleared pages into <content-dir>, de-link
# anything outside the set, and generate a landing index.md. Prints an include/exclude summary.
# In dry mode it prints the summary and writes nothing. Returns 1 if the role is unknown.
stage_role() {
  role="$1"; out="$2"
  allowed="$(awk -F'\t' -v r="$role" '$1==r{print $2; exit}' "$ROLES")"
  [ -n "$allowed" ] || { echo "publish: role '$role' not in roles.tsv (have: $(list_roles))" >&2; return 1; }
  allow_re="^($(printf '%s' "$allowed" | tr -d ' ' | tr ',' '|'))$"

  inc_file="$(mktemp)"; tiers_tmp="$(mktemp)"
  incn=0; exc=0; qz=0
  for f in $(find "$WIKI" -name '*.md' | sort); do
    base="$(basename "$f" .md)"
    case "$(kb_type_class "$(fm_type "$f")")" in nav) continue;; esac   # catalogs/home; Quartz builds nav
    [ "$(fm_relev "$f")" = off-topic ] && { qz=$((qz+1)); continue; }   # quarantined (off-charter) page
    pv="$(fm_priv "$f")"; pv="${pv:-$DEFAULT_TIER}"
    if printf '%s' "$pv" | grep -qE "$allow_re"; then
      printf '%s\n' "$base" >> "$inc_file"; incn=$((incn+1))
      printf '%s\n' "$pv" >> "$tiers_tmp"
    else
      exc=$((exc+1))
    fi
  done

  brk="$(for t in $(kb_tiers); do c="$(grep -cxF "$t" "$tiers_tmp" 2>/dev/null || true)"; printf ' %s=%s' "$t" "$c"; done)"
  rm -f "$tiers_tmp"
  printf 'publish[%s]: clearance = %s\n' "$role" "$allowed"
  printf '  include %d ·%s · exclude %d above clearance%s\n' "$incn" "$brk" "$exc" "$([ "$qz" -gt 0 ] && printf ', %d quarantined' "$qz")"
  if [ "$MODE" = dry ]; then rm -f "$inc_file"; return 0; fi

  rm -rf "$out"; mkdir -p "$out"
  for f in $(find "$WIKI" -name '*.md' | sort); do
    base="$(basename "$f" .md)"; grep -qxF "$base" "$inc_file" || continue
    rel="${f#"$WIKI"/}"; dest="$out/$rel"; mkdir -p "$(dirname "$dest")"
    INC="$inc_file" perl -pe '
      BEGIN { open my $fh,"<",$ENV{INC}; while(<$fh>){chomp; $inc{$_}=1} }
      s{(\[\[([^]|#]+)(?:#[^]|]*)?(?:\|([^]]+))?\]\])}{ exists $inc{$2} ? $1 : ($3 // $2) }ge;  # de-link excluded
      s{\[([^\]]*)\]\(\.\.\/raw\/[^)]*\)}{$1}g;                                                   # de-link raw citations
    ' "$f" > "$dest"
  done

  # Quartz serves content/index.md at the site root; the wiki's index/overview were skipped,
  # so synthesize a minimal landing page for this role view (else "/" 404s).
  {
    printf -- '---\ntitle: %s\n---\n\n' "$TITLE"
    printf '# %s\n\nThe **%s** view of this knowledge base. Browse with the explorer or search, or start from the pages below.\n\n' "$TITLE" "$role"
    # Most asked about: the most-queried pages that are in THIS role's view (deterministic,
    # from queries.tsv; the wiki's overview.md is skipped, so prominence reaches the site here).
    if [ -f "$QUERIES" ]; then
      top="$(awk -F'\t' 'NR==FNR{inc[$1]=1;next} $1~/^#/||$1==""{next} ($2 in inc){c[$2]++} END{for(p in c)printf "%d\t%s\n",c[p],p}' "$inc_file" "$QUERIES" | sort -rn | head -5)"
      if [ -n "$top" ]; then
        printf '## Most asked about\n\n'
        printf '%s\n' "$top" | while IFS=$'\t' read -r n p; do [ -n "$p" ] && printf -- '- [[%s]]\n' "$p"; done
        printf '\n'
      fi
    fi
    printf '## Pages\n\n'
    while IFS= read -r s; do [ -n "$s" ] && printf -- '- [[%s]]\n' "$s"; done < "$inc_file"
  } > "$out/index.md"

  rm -f "$inc_file"
  printf '  staged → %s\n' "${out#"$KB_DIR"/}"
}

# ensure_quartz: make $QZ a working Quartz checkout (one-off clone + npm i + plugin install).
# Returns 0 when ready, 1 when it can't be (prints why); the install is disposable.
ensure_quartz() {
  if [ ! -f "$QZ/package.json" ]; then
    if command -v git >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
      printf 'publish: Quartz not found — one-off install into %s (clone + npm i, may take a minute) ...\n' "${QZ#"$KB_DIR"/}"
      rm -rf "$QZ"
      if git clone --depth 1 https://github.com/jackyzha0/quartz "$QZ" >/dev/null 2>&1 && ( cd "$QZ" && npm i >/dev/null 2>&1 ); then
        echo "  Quartz installed."
      else
        rm -rf "$QZ"   # leave nothing half-built; a re-run retries cleanly
        echo "publish: Quartz install failed (network or npm)." >&2
        return 1
      fi
    else
      echo "publish: git and npm are needed to auto-install Quartz." >&2
      echo "  install Node and git, then re-run (or point QUARTZ_DIR at an existing Quartz)." >&2
      return 1
    fi
  fi
  # Quartz v5+ generates its plugin barrel (.quartz/) via `plugin install`; a fresh clone
  # needs it, else the build fails with: Could not resolve "../../.quartz/plugins".
  if [ ! -d "$QZ/.quartz" ]; then
    printf 'publish: installing Quartz plugins (one-off) ...\n'
    ( cd "$QZ" && npx quartz plugin install ) || { echo "publish: 'npx quartz plugin install' failed." >&2; return 1; }
  fi
  return 0
}

if [ "$ALL" = 0 ]; then
  OUT="$KB_DIR/.publish/$ROLE/content"
  stage_role "$ROLE" "$OUT" || exit 1
  [ "$MODE" = dry ] && exit 0
  ensure_quartz || { printf 'publish[%s]: content staged at %s; install Node+git (or set QUARTZ_DIR) and re-run.\n' "$ROLE" "${OUT#"$KB_DIR"/}" >&2; exit 0; }
  quartz_set_title "$TITLE"
  # Clear BOTH the staged content and the built output: a stale public/ from a previous
  # (higher-clearance) role would otherwise be served, leaking pages this role cannot see.
  rm -rf "$QZ/content" "$QZ/public"; cp -R "$OUT" "$QZ/content"
  if [ "$MODE" = serve ]; then
    printf 'publish[%s]: serving live preview at http://localhost:8080 (Ctrl-C to stop) ...\n' "$ROLE"
    ( cd "$QZ" && npx quartz build --serve )
  else
    ( cd "$QZ" && npx quartz build ) && printf 'publish[%s]: built → %s/public\n' "$ROLE" "$QZ"
  fi
else
  # --all: stage + build every role into its own static output dir.
  QZOK=1
  [ "$MODE" = dry ] || ensure_quartz || QZOK=0
  [ "$MODE" != dry ] && [ "$QZOK" = 1 ] && quartz_set_title "$TITLE"
  built=""
  for role in $(all_roles); do
    [ -n "$role" ] || continue
    OUT="$KB_DIR/.publish/$role/content"
    stage_role "$role" "$OUT" || continue
    { [ "$MODE" = dry ] || [ "$QZOK" = 0 ]; } && continue
    rm -rf "$QZ/content" "$QZ/public"; cp -R "$OUT" "$QZ/content"
    ( cd "$QZ" && npx quartz build ) >/dev/null
    site="$KB_DIR/.publish/sites/$role"
    rm -rf "$site"; mkdir -p "$site"; cp -R "$QZ/public/." "$site/"
    printf '  site → %s\n' "${site#"$KB_DIR"/}"
    built="$built $role"
  done
  [ "$MODE" = dry ] && exit 0
  if [ "$QZOK" = 0 ]; then
    echo "publish --all: content staged per role under .publish/<role>/content/; Quartz unavailable, no sites built." >&2
    exit 0
  fi
  printf 'publish --all: built%s → .publish/sites/<role>/\n' "$built"
  echo "  open a site directly (open .publish/sites/<role>/index.html) or serve one live: ./scripts/publish <role> --serve"
fi
