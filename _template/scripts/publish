#!/usr/bin/env bash
# publish — build a role-filtered, shareable view of the wiki (for Quartz or any site).
#
#   ./scripts/publish <role>            stage the role's allowed pages; build with Quartz if set up
#   ./scripts/publish <role> --dry-run  report what would be included/excluded; write nothing
#   ./scripts/publish <role> --stage    stage filtered content only; do not build
#
# Roles and the privilege tiers each may see are defined in .publish/roles.tsv. Pages above a
# role's clearance are excluded; links to excluded pages and all ../raw/ citation links are
# de-linked so the published site has no broken links and no paths into private sources.
# index.md and overview.md are skipped (they catalog the whole graph); Quartz builds its own
# navigation. Quartz runs only if QUARTZ_DIR points at a Quartz project; otherwise content is
# staged and instructions are printed (the filtering itself needs no Node).

set -eu
KB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WIKI="$KB_DIR/wiki"
ROLES="$KB_DIR/.publish/roles.tsv"
ROLE="${1:-}"; MODE=build
case "${2:-}" in --dry-run) MODE=dry;; --stage) MODE=stage;; "") ;; *) echo "publish: unknown arg '$2'" >&2; exit 1;; esac

list_roles() { grep -v '^#' "$ROLES" 2>/dev/null | cut -f1 | paste -sd' ' -; }
[ -f "$ROLES" ] || { echo "publish: no .publish/roles.tsv" >&2; exit 1; }
[ -n "$ROLE" ] || { echo "usage: publish <role> [--dry-run|--stage]   (roles: $(list_roles))"; exit 1; }
[ -d "$WIKI" ] || { echo "publish: no wiki/ yet."; exit 0; }

allowed="$(awk -F'\t' -v r="$ROLE" '$1==r{print $2; exit}' "$ROLES")"
[ -n "$allowed" ] || { echo "publish: role '$ROLE' not in roles.tsv (have: $(list_roles))" >&2; exit 1; }
allow_re="^($(printf '%s' "$allowed" | tr -d ' ' | tr ',' '|'))$"
fm_priv() { awk -F': ' '/^privilege:/{print $2; exit}' "$1"; }

inc_file="$(mktemp)"; trap 'rm -f "$inc_file"' EXIT
incn=0; exc=0; pP=0; pB=0; pD=0
for f in $(find "$WIKI" -name '*.md' | sort); do
  base="$(basename "$f" .md)"
  case "$base" in index|overview) continue;; esac     # catalogs; Quartz builds nav
  pv="$(fm_priv "$f")"; pv="${pv:-default}"
  if printf '%s' "$pv" | grep -qE "$allow_re"; then
    printf '%s\n' "$base" >> "$inc_file"; incn=$((incn+1))
    case "$pv" in personal-sensitive) pP=$((pP+1));; business-sensitive) pB=$((pB+1));; *) pD=$((pD+1));; esac
  else
    exc=$((exc+1))
  fi
done

printf 'publish[%s]: clearance = %s\n' "$ROLE" "$allowed"
printf '  include %d (default %d, business %d, personal %d) · exclude %d above clearance\n' "$incn" "$pD" "$pB" "$pP" "$exc"
[ "$MODE" = "dry" ] && { echo "  (dry-run; nothing staged)"; exit 0; }

OUT="$KB_DIR/.publish/$ROLE/content"
rm -rf "$KB_DIR/.publish/$ROLE"; mkdir -p "$OUT"
for f in $(find "$WIKI" -name '*.md' | sort); do
  base="$(basename "$f" .md)"; grep -qxF "$base" "$inc_file" || continue
  rel="${f#"$WIKI"/}"; dest="$OUT/$rel"; mkdir -p "$(dirname "$dest")"
  INC="$inc_file" perl -pe '
    BEGIN { open my $fh,"<",$ENV{INC}; while(<$fh>){chomp; $inc{$_}=1} }
    s{(\[\[([^]|#]+)(?:#[^]|]*)?(?:\|([^]]+))?\]\])}{ exists $inc{$2} ? $1 : ($3 // $2) }ge;  # de-link excluded
    s{\[([^\]]*)\]\(\.\.\/raw\/[^)]*\)}{$1}g;                                                   # de-link raw citations
  ' "$f" > "$dest"
done
printf '  staged → %s\n' "${OUT#"$KB_DIR"/}"
[ "$MODE" = "stage" ] && exit 0

QZ="${QUARTZ_DIR:-$KB_DIR/.publish/quartz}"
if [ -d "$QZ" ] && [ -f "$QZ/package.json" ]; then
  rm -rf "$QZ/content"; cp -R "$OUT" "$QZ/content"
  ( cd "$QZ" && npx quartz build ) && printf 'publish[%s]: built → %s/public\n' "$ROLE" "$QZ"
else
  printf 'publish[%s]: Quartz not set up; content is staged.\n' "$ROLE"
  printf '  one-time: git clone https://github.com/jackyzha0/quartz "%s" && (cd "%s" && npm i)\n' "$QZ" "$QZ"
  printf '  then re-run, or: cp -R "%s"/* "%s"/content/ && (cd "%s" && npx quartz build)\n' "$OUT" "$QZ" "$QZ"
fi
