#!/usr/bin/env bash
# lint — mechanical QA over the wiki (no LLM, no cost). Structural + style + privacy checks.
#
#   ./scripts/lint            run all checks; exit 0 if no ERRORS, 1 if any
#   ./scripts/lint --quiet    print only ERRORS and the summary
#
# ERRORS are clear defects (missing Sources, bad frontmatter). WARNINGS are smells to
# review (orphans, no-read-source pages, stale derived, style tells, privacy hits).
# This is the cheap pre-check; the LLM Lint workflow and the verify pass go deeper.

set -eu   # no pipefail: `grep ... | wc` deliberately tolerates no-match
KB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$KB_DIR/scripts/kblib.sh"   # page-type + privilege-tier vocabularies (.schema/)
WIKI="$KB_DIR/wiki"
QUIET=0; [ "${1:-}" = "--quiet" ] && QUIET=1
[ -d "$WIKI" ] || { echo "lint: no wiki/ yet."; exit 0; }

ERR=0; WARN=0
err()  { ERR=$((ERR+1));  printf 'ERROR   %s\n' "$1"; }
warn() { WARN=$((WARN+1)); [ "$QUIET" -eq 1 ] || printf 'warn    %s\n' "$1"; }
sect() { [ "$QUIET" -eq 1 ] || printf '\n— %s —\n' "$1"; }

pages="$(find "$WIKI" -name '*.md' | sort)"
slugs="$(for f in $pages; do basename "$f" .md; done | sort -u)"
fm() { awk -F': ' -v k="^$2:" '$0 ~ k {sub(/^[^:]*: */,""); print; exit}' "$1"; }

printf '══════ lint: %s/wiki ══════\n' "$(basename "$KB_DIR")"

# --- frontmatter completeness + valid enums ---------------------------------
sect "frontmatter"
for f in $pages; do
  rel=${f#"$WIKI"/}
  for k in type privilege created updated; do
    grep -qE "^$k:" "$f" || err "$rel: missing frontmatter '$k:'"
  done
  pv="$(fm "$f" privilege)"
  [ -z "$pv" ] || kb_tier_valid "$pv" || warn "$rel: unknown privilege '$pv' (not in .schema/privilege-tiers.tsv)"
  ty="$(fm "$f" type)"
  [ -z "$ty" ] || kb_type_valid "$ty" || warn "$rel: unknown type '$ty' (not in .schema/page-types.tsv)"
  rv="$(fm "$f" relevance)"
  case "${rv:-}" in ''|relevant|off-topic) ;; *) warn "$rel: unknown relevance '$rv' (use relevant | off-topic)";; esac
  mb="$(fm "$f" maintained_by)"
  case "${mb:-}" in ''|agent|human) ;; *) warn "$rel: unknown maintained_by '$mb' (use agent | human)";; esac
done

# --- content pages should have ## Sources; flag all-not-read pages ----------
# (source pages describe the source itself, so they are exempt)
sect "citations"
for f in $pages; do
  rel=${f#"$WIKI"/}; ty="$(fm "$f" type)"
  [ "$(kb_type_class "$ty")" = content ] || continue   # only content pages must cite
  [ "$(fm "$f" maintained_by)" = human ] && continue   # owner-authored: their content, their call
  if ! grep -qE '^## Sources' "$f"; then warn "$rel: type=$ty but no '## Sources' section (un-cited / not yet deepened)"; continue; fi
  src="$(sed -n '/^## Sources/,$p' "$f")"
  total=$(printf '%s\n' "$src" | grep -cE '^- ' || true)
  rin=$(printf '%s\n' "$src" | grep -cE 'read in full' || true)
  [ "${total:-0}" -gt 0 ] && [ "${rin:-0}" -eq 0 ] && warn "$rel: every source marked 'not read' (claims may be inferred)"
done

# --- dangling wikilinks + orphans -------------------------------------------
sect "links"
targets="$(grep -rhoE '\[\[[^]]+\]\]' "$WIKI" --include='*.md' 2>/dev/null | sed -E 's/\[\[([^]|#]+).*/\1/' | sort -u || true)"
for t in $targets; do
  printf '%s\n' "$slugs" | grep -qxF "$t" || warn "dangling [[${t}]] — no page named ${t}.md"
done
for s in $slugs; do
  case "$s" in index|overview) continue;; esac
  cnt=$(grep -rlE "\[\[${s}[]|#]" "$WIKI" --include='*.md' 2>/dev/null | grep -vc "/${s}\.md" || true)
  [ "${cnt:-0}" -eq 0 ] && warn "orphan: ${s}.md has no inbound [[links]]"
done

# --- thin pages: very short content with no inbound links (possible noise) ---
sect "thin pages"
for f in $pages; do
  rel=${f#"$WIKI"/}; ty="$(fm "$f" type)"
  [ "$(kb_type_class "$ty")" = content ] || continue
  [ "$(fm "$f" relevance)" = off-topic ] && continue   # already quarantined
  [ "$(fm "$f" maintained_by)" = human ] && continue   # owner-authored; may be brief by design
  base="$(basename "$f" .md)"
  body="$(awk 'NR==1&&/^---/{infm=1;next} infm&&/^---/{infm=0;next} infm{next} /^## Sources/{exit} {print}' "$f")"
  words=$(printf '%s' "$body" | wc -w | tr -d ' ')
  inb=$(grep -rlE "\[\[${base}[]|#]" "$WIKI" --include='*.md' 2>/dev/null | grep -vc "/${base}\.md" || true)
  [ "${words:-0}" -lt 25 ] && [ "${inb:-0}" -eq 0 ] \
    && warn "thin: $rel ($words words, no inbound links) — possible noise; deepen, link, or quarantine (relevance: off-topic)"
done

# --- stale derived pages (derived_from page updated > this as_of) -----------
sect "freshness"
for f in $pages; do
  rel=${f#"$WIKI"/}; asof="$(fm "$f" as_of)"; [ -n "$asof" ] || continue
  for d in $(grep -E '^derived_from:' "$f" | grep -oE '\[\[[^]]+\]\]' | sed -E 's/\[\[([^]|#]+).*/\1/'); do
    dfile=$(printf '%s\n' $pages | grep -E "/${d}\.md$" | head -1 || true); [ -n "$dfile" ] || continue
    dupd="$(fm "$dfile" updated)"; [ -n "$dupd" ] || continue
    [[ "$dupd" > "$asof" ]] && warn "$rel: stale — [[${d}]] updated $dupd > as_of $asof"
  done
done

# --- style tells -------------------------------------------------------------
sect "style"
bv=$(grep -rhoiwE 'crucial|robust|comprehensive|multifaceted|seamless|vibrant|boasts|nestled|testament|showcase[sd]?|underscore[sd]?|pivotal|delve|tapestry|renowned|groundbreaking|leverage[sd]?|intricate|meticulous' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
[ "${bv:-0}" -gt 0 ] && warn "style: $bv banned-vocabulary occurrence(s)"
cq=$(grep -rho '[“”‘’]' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
[ "${cq:-0}" -gt 0 ] && warn "style: $cq curly quote(s)/apostrophe(s) (use straight)"
for f in $pages; do
  rel=${f#"$WIKI"/}; d=$(grep -o '—' "$f" 2>/dev/null | wc -l | tr -d ' ')
  [ "${d:-0}" -gt 12 ] && warn "style: $rel has $d em-dashes (overuse)"
done

# --- no ingestion mechanics / provenance in prose (body only) ---------------
# The page body is about its subject; how it was ingested, where the raw file lives, and
# what it was derived from belong in `## Sources`, frontmatter, and coverage.tsv, not prose.
# Source pages are exempt (the source itself is their subject). See STYLE.md §10.
sect "prose hygiene"
# A body mention of a source page's own slug is provenance ("drawn from [[shared-drive]]");
# that belongs in ## Sources, so fold the source slugs into the pattern (KB-agnostic).
srcre="$(for f in $pages; do [ "$(kb_type_class "$(fm "$f" type)")" = source ] && basename "$f" .md; done | paste -sd'|' - || true)"
pat='read in full|not read|this pass|map pass|deferred to a later|first ingest|derived from|coverage row|[Ss]ource:'
[ -n "$srcre" ] && pat="$pat|\\[\\[($srcre)([]|#])"
for f in $pages; do
  rel=${f#"$WIKI"/}; ty="$(fm "$f" type)"
  case "$(kb_type_class "$ty")" in source) continue;; esac   # source pages: provenance is their subject
  [ "$ty" = index ] && continue                              # the catalog is an auto-generated link list
  [ "$(fm "$f" maintained_by)" = human ] && continue         # owner-authored: not the agent's prose to police
  body="$(awk 'NR==1&&/^---/{infm=1;next} infm&&/^---/{infm=0;next} infm{next} /^## Sources/{exit} {print}' "$f")"
  hit="$(printf '%s\n' "$body" | grep -inE "$pat" || true)"
  if [ -n "$hit" ]; then
    ex="$(printf '%s' "$hit" | head -1 | sed 's/^[0-9]*://; s/^ *//' | cut -c1-58)"
    warn "$rel: ingestion-mechanics/provenance in prose (STYLE.md §10): $ex"
  fi
done

# --- privacy heuristics (report for human review; never fail) ---------------
sect "privacy"
sin="$(grep -rnoE '\b[0-9]{3}-[0-9]{3}-[0-9]{3}\b' "$WIKI" --include='*.md' 2>/dev/null || true)"
[ -n "$sin" ] && { warn "privacy: SIN-shaped number(s) found — confirm these are NOT SINs:"; printf '%s\n' "$sin" | sed 's/^/          /'; }
cred="$(grep -rinE 'social insurance|company key|corporation key|\brecovery code\b|\bpassword\b' "$WIKI" --include='*.md' 2>/dev/null | grep -vi 'not recorded' || true)"
[ -n "$cred" ] && warn "privacy: credential/identifier keyword(s) present — review (grep for them)"

# --- docs style (STYLE.md governs docs/READMEs too, not just wiki pages) -----
# Excludes STYLE.md (it names the banned words), notes.md (owner-authored), and
# docs/llm-wiki-pattern.md (external reference, kept verbatim).
sect "docs style"
DOC_LIST="$KB_DIR/AGENTS.md $KB_DIR/CLAUDE.md $KB_DIR/README.md $KB_DIR/scripts/README.md $KB_DIR/inbox/README.md $KB_DIR/junk/README.md"
for d in "$KB_DIR"/docs/*.md; do
  [ -e "$d" ] || continue
  case "$d" in */llm-wiki-pattern.md) continue;; esac
  DOC_LIST="$DOC_LIST $d"
done
for d in $DOC_LIST; do
  [ -f "$d" ] || continue
  rel=${d#"$KB_DIR"/}
  dem=$(grep -o '—' "$d" 2>/dev/null | wc -l | tr -d ' ')
  [ "${dem:-0}" -gt 3 ] && warn "docs: $rel has $dem em-dashes (overuse — STYLE.md)"
  dbv=$(grep -hoiwE 'crucial|robust|comprehensive|multifaceted|seamless|vibrant|boasts|nestled|testament|showcase[sd]?|delve|tapestry|renowned|groundbreaking|pivotal|underscore[sd]?' "$d" 2>/dev/null | wc -l | tr -d ' ')
  [ "${dbv:-0}" -gt 0 ] && warn "docs: $rel has $dbv banned-vocabulary occurrence(s)"
  dcq=$(grep -o '[“”‘’]' "$d" 2>/dev/null | wc -l | tr -d ' ')
  [ "${dcq:-0}" -gt 0 ] && warn "docs: $rel has $dcq curly quote(s)"
done

# --- summary -----------------------------------------------------------------
printf '\n══════ %d error(s), %d warning(s) ══════\n' "$ERR" "$WARN"
[ "$ERR" -eq 0 ] || exit 1
