#!/usr/bin/env bash
# scan — detect new/changed/removed sources in raw/ vs the ingest manifest.
#
# Each top-level entry in raw/ is one source (file, directory, or symlink to a living
# document). Fingerprints follow symlinks. The diff is against .ingest/manifest.tsv. Names in
# .ingestignore and zero-byte files are skipped as junk (as whole sources, and inside directory
# sources so junk does not affect a fingerprint); sources with identical content are flagged as
# possible duplicates.
#
#   ./scan            detect; write .ingest/pending.md; exit 0 = clean, 10 = pending
#   ./scan --accept   advance the manifest baseline to current state (used post-ingest)
#   ./scan --refresh  freshness check: fingerprint read coverage items, flag changed = stale
#
# No LLM, no network, no cost. Portable across macOS (bash 3.2 / BSD tools) and Linux.

set -euo pipefail

die() { printf 'scan: error: %s\n' "$1" >&2; exit 1; }

MODE="detect"
case "${1:-}" in
  --accept)  MODE="accept";;
  --refresh) MODE="refresh";;
esac

KB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$KB_DIR/scripts/kblib.sh"   # .ingestignore junk filter (kb_skip / kb_ignored)
RAW_DIR="$KB_DIR/raw"
STATE_DIR="$KB_DIR/.ingest"
MANIFEST="$STATE_DIR/manifest.tsv"
PENDING="$STATE_DIR/pending.md"
COVERAGE="$STATE_DIR/coverage.tsv"
DATE="$(date +%F)"

MANIFEST_HEADER=$'# manifest.tsv — ingest baseline. Columns: source_path\tkind\tfingerprint\tlast_ingested\n# Managed by scripts/scan (--accept). Do not edit by hand.'

[ -d "$RAW_DIR" ] || die "no raw/ at $RAW_DIR"
mkdir -p "$STATE_DIR"
[ -f "$MANIFEST" ] || printf '%s\n' "$MANIFEST_HEADER" > "$MANIFEST"

# --- portable hashing + stat -------------------------------------------------
if command -v shasum >/dev/null 2>&1; then
  _hash() { shasum -a 256 | cut -d' ' -f1; }
elif command -v sha256sum >/dev/null 2>&1; then
  _hash() { sha256sum | cut -d' ' -f1; }
else
  die "need shasum or sha256sum on PATH"
fi

if stat -f '%z' . >/dev/null 2>&1; then
  _statline() { stat -f '%z %m' "$1"; }   # BSD / macOS: <size> <mtime>
else
  _statline() { stat -c '%s %Y' "$1"; }   # GNU / Linux
fi

# fingerprint = hash of (relative-path size mtime) for every non-junk file under the source,
# sorted for stability. Follows symlinks (-L) so living symlink targets are covered.
fingerprint() {
  find -L "$1" -type f 2>/dev/null | LC_ALL=C sort | while IFS= read -r f; do
    kb_ignored "${f##*/}" && continue
    printf '%s %s\n' "$f" "$(_statline "$f")"
  done | _hash
}

# size_sig = "<total-bytes>_<file-count>" over non-junk files. Cheap (stat only); used to find
# duplicate CANDIDATES before the more expensive content hash.
size_sig() {
  find -L "$1" -type f 2>/dev/null | while IFS= read -r f; do
    kb_ignored "${f##*/}" && continue
    _statline "$f"
  done | awk '{s+=$1; n++} END{printf "%s_%s", s+0, n+0}'
}

# content_hash = path-independent hash of file CONTENTS (sorted, non-junk). Detects exact
# duplicates wherever they sit. Only run on size-collision candidates.
content_hash() {
  find -L "$1" -type f 2>/dev/null | LC_ALL=C sort | while IFS= read -r f; do
    kb_ignored "${f##*/}" && continue
    _hash < "$f"
  done | _hash
}

kind_of() {
  if [ -L "$1" ]; then echo "symlink-living"
  elif [ -d "$1" ]; then echo "directory"
  else echo "file"; fi
}

# --- refresh: freshness check over coverage.tsv (crawler-style re-fetch detection) -------
# For each read/partial coverage row whose `path` resolves under raw/: fingerprint it.
# Empty fingerprint -> baseline it (record the version that was read). Changed since the
# baseline -> flip status to `stale`. Importance ('value') is untouched — this only flags
# AGE; the deepen pass weighs age × value when picking what to (re-)read.
if [ "$MODE" = "refresh" ]; then
  [ -f "$COVERAGE" ] || { echo "scan: no coverage.tsv yet — run a map pass first."; exit 0; }
  tmp="$(mktemp)"; trap 'rm -f "$tmp"' EXIT
  grep '^#' "$COVERAGE" > "$tmp" || true
  checked=0; baselined=0; staled=0
  while IFS=$'\t' read -r path value status pass last_read fp notes; do
    [ -z "${path:-}" ] && continue
    if [ "${status:-}" = "read" ] || [ "${status:-}" = "partial" ]; then
      full="$RAW_DIR/$path"
      if [ -e "$full" ] || [ -L "$full" ]; then
        checked=$((checked + 1))
        cur="$(fingerprint "$full")"
        if [ -z "${fp:-}" ] || [ "$fp" = "-" ]; then fp="$cur"; baselined=$((baselined + 1))
        elif [ "$cur" != "$fp" ]; then status="stale"; staled=$((staled + 1)); fi
      fi
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$path" "${value:-}" "${status:-}" "${pass:-}" "${last_read:-}" "${fp:--}" "${notes:-}" >> "$tmp"
  done < <(grep -v '^#' "$COVERAGE")
  mv "$tmp" "$COVERAGE"; trap - EXIT
  printf 'scan: freshness — %d checked, %d baselined, %d now stale → %s\n' \
    "$checked" "$baselined" "$staled" "${COVERAGE#"$KB_DIR"/}"
  [ "$staled" -gt 0 ] && exit 10 || exit 0
fi

SEEN_FILE="$(mktemp)"; SIG_FILE="$(mktemp)"; trap 'rm -f "$SEEN_FILE" "$SIG_FILE"' EXIT
NEW=(); CHANGED=(); NEWMAN=(); SKIPPED=()

shopt -s nullglob
for src in "$RAW_DIR"/*; do
  base="$(basename "$src")"
  case "$base" in README.md|.*) continue;; esac
  if kb_skip "$src"; then SKIPPED+=("raw/$base"); continue; fi   # .ingestignore / zero-byte
  rel="raw/$base"
  printf '%s\n' "$rel" >> "$SEEN_FILE"
  fp="$(fingerprint "$src")"
  printf '%s\t%s\n' "$rel" "$(size_sig "$src")" >> "$SIG_FILE"
  kind="$(kind_of "$src")"
  prior_line="$(awk -F'\t' -v p="$rel" '$1==p{print; exit}' "$MANIFEST")"
  if [ -z "$prior_line" ]; then
    NEW+=("$rel ($kind)"); last="$DATE"
  else
    prior_fp="$(printf '%s' "$prior_line" | cut -f3)"
    prior_last="$(printf '%s' "$prior_line" | cut -f4)"
    if [ "$prior_fp" != "$fp" ]; then
      CHANGED+=("$rel ($kind)"); last="$DATE"
    else
      last="${prior_last:-$DATE}"
    fi
  fi
  NEWMAN+=("$rel	$kind	$fp	$last")
done
shopt -u nullglob

# removed = rows in the manifest whose path no longer exists in raw/
REMOVED=()
while IFS=$'\t' read -r path _k _f _l; do
  case "${path:-}" in ''|'#'*) continue;; esac
  grep -qxF "$path" "$SEEN_FILE" || REMOVED+=("$path")
done < "$MANIFEST"

# --- duplicates: sources sharing a size signature, confirmed by content hash -----------
# Size collisions are rare, so a content hash runs only for candidates that share a signature.
DUPES=()
while IFS= read -r sig; do
  [ -n "$sig" ] || continue
  ch_file="$(mktemp)"
  while IFS= read -r rel; do
    [ -n "$rel" ] || continue
    printf '%s\t%s\n' "$(content_hash "$RAW_DIR/${rel#raw/}")" "$rel" >> "$ch_file"
  done < <(awk -F'\t' -v s="$sig" '$2==s{print $1}' "$SIG_FILE")
  while IFS= read -r h; do
    [ -n "$h" ] || continue
    grp="$(awk -F'\t' -v hh="$h" '$1==hh{print $2}' "$ch_file" | paste -sd'|' - | sed 's/|/ = /g')"
    DUPES+=("$grp")
  done < <(cut -f1 "$ch_file" | sort | uniq -d)
  rm -f "$ch_file"
done < <(cut -f2 "$SIG_FILE" | sort | uniq -d)

# --- accept: rewrite manifest to current state, then stop --------------------
if [ "$MODE" = "accept" ]; then
  { printf '%s\n' "$MANIFEST_HEADER"
    for row in "${NEWMAN[@]:-}"; do [ -n "$row" ] && printf '%s\n' "$row"; done
  } > "$MANIFEST"
  printf '# Pending ingest\n\n_Baseline accepted on %s — nothing pending._\n' "$DATE" > "$PENDING"
  printf 'scan: baseline advanced (%d sources). Manifest up to date.\n' "${#NEWMAN[@]}"
  exit 0
fi

# --- write pending.md --------------------------------------------------------
{
  printf '# Pending ingest — generated by scan on %s\n\n' "$DATE"
  printf '_Do not edit by hand; regenerated on every scan._\n\n'
  printf '## New (%d)\n' "${#NEW[@]}"
  if [ "${#NEW[@]}" -eq 0 ]; then printf '_none_\n'; else for x in "${NEW[@]}"; do printf -- '- `%s`\n' "$x"; done; fi
  printf '\n## Changed (%d)\n' "${#CHANGED[@]}"
  if [ "${#CHANGED[@]}" -eq 0 ]; then printf '_none_\n'; else for x in "${CHANGED[@]}"; do printf -- '- `%s`\n' "$x"; done; fi
  printf '\n## Removed (%d)\n' "${#REMOVED[@]}"
  if [ "${#REMOVED[@]}" -eq 0 ]; then printf '_none_\n'; else for x in "${REMOVED[@]}"; do printf -- '- `%s`\n' "$x"; done; fi
  printf '\n## Skipped as junk (%d)\n' "${#SKIPPED[@]}"
  if [ "${#SKIPPED[@]}" -eq 0 ]; then printf '_none_\n'; else for x in "${SKIPPED[@]}"; do printf -- '- `%s`\n' "$x"; done; fi
  printf '\n## Possible duplicates (%d)\n' "${#DUPES[@]}"
  if [ "${#DUPES[@]}" -eq 0 ]; then printf '_none_\n'; else for x in "${DUPES[@]}"; do printf -- '- %s\n' "$x"; done; fi
} > "$PENDING"

PEND=$(( ${#NEW[@]} + ${#CHANGED[@]} + ${#REMOVED[@]} ))
printf 'scan: %d new, %d changed, %d removed, %d skipped, %d dup-group(s) → %s\n' \
  "${#NEW[@]}" "${#CHANGED[@]}" "${#REMOVED[@]}" "${#SKIPPED[@]}" "${#DUPES[@]}" "${PENDING#"$KB_DIR"/}"
[ "$PEND" -eq 0 ] && exit 0 || exit 10
