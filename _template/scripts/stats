#!/usr/bin/env bash
# stats — summarise the ingestion state of this knowledge base. No LLM, no cost.
#
#   ./scripts/stats           print the report
#   ./scripts/stats --check   also resolve each coverage path under raw/ (flags missing/unreadable)
#                             (only meaningful where raw/ resolves — your real machine, not a container)
#
# Reads .ingest/{coverage,manifest,cost}.tsv and wiki/. Read-only; writes nothing.

set -eu   # no pipefail: `grep ... | wc` deliberately tolerates no-match

KB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COVERAGE="$KB_DIR/.ingest/coverage.tsv"
MANIFEST="$KB_DIR/.ingest/manifest.tsv"
QA="$KB_DIR/.ingest/qa.tsv"
SENS="$KB_DIR/.ingest/sensitivity.tsv"
RELEVANCE="$KB_DIR/.ingest/relevance.tsv"
COST="$KB_DIR/.ingest/cost.tsv"
DEMAND="$KB_DIR/.ingest/demand.tsv"
QUERIES="$KB_DIR/.ingest/queries.tsv"
WIKI="$KB_DIR/wiki"
RAW="$KB_DIR/raw"
CHECK=0; [ "${1:-}" = "--check" ] && CHECK=1

rule() { printf '%s\n' "────────────────────────────────────────────────"; }
have() { [ -f "$1" ] && [ "$(grep -vc '^#' "$1" 2>/dev/null || true)" -gt 0 ]; }

printf '\n══════ %s — ingestion stats ══════\n' "$(basename "$KB_DIR")"

# --- sources (manifest) ------------------------------------------------------
nsrc=0; [ -f "$MANIFEST" ] && nsrc=$(grep -vc '^#' "$MANIFEST" 2>/dev/null || true)
printf '\nSOURCES        %s tracked in raw/ (manifest)\n' "$nsrc"

# --- documents (coverage frontier) -------------------------------------------
printf '\nDOCUMENTS (coverage frontier)\n'; rule
if have "$COVERAGE"; then
  awk -F'\t' '
    function bar(n,t,  w,f,s,i){w=22; if(t<=0)return; f=int(n*w/t+0.5); s="";
      for(i=0;i<f;i++)s=s"#"; for(i=f;i<w;i++)s=s"."; return s}
    $1 ~ /^#/ || $1=="" {next}
    {tot++; st[$3]++; val[$2]++;
     if($3=="unread"||$3=="stale"){fr++; if($2=="high")hf++}}
    END{
      printf "  total tracked   %d\n", tot
      printf "  read     %4d  %s\n", st["read"]+0,    bar(st["read"]+0,tot)
      printf "  partial  %4d  %s\n", st["partial"]+0, bar(st["partial"]+0,tot)
      printf "  unread   %4d  %s\n", st["unread"]+0,  bar(st["unread"]+0,tot)
      printf "  stale    %4d  %s\n", st["stale"]+0,   bar(st["stale"]+0,tot)
      printf "  by value        high %d / med %d / low %d\n", val["high"]+0, val["med"]+0, val["low"]+0
      printf "  frontier        %d to do (unread+stale); %d of them high-value\n", fr+0, hf+0
      if(tot>0) printf "  coverage        %d%% read or partial\n", int(((st["read"]+0)+(st["partial"]+0))*100/tot)
    }' "$COVERAGE"
else
  printf '  (none yet — run ./scripts/ingest --map)\n'
fi

# --- read attempts (from wiki citations) — surfaces "unreadable" docs --------
printf '\nREAD ATTEMPTS (from wiki ## Sources)\n'; rule
if [ -d "$WIKI" ]; then
  rin=$(grep -rhoE 'read in full' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
  nrd=$(grep -rhoE 'not read' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
  printf '  read in full    %s\n  not read        %s\n' "$rin" "$nrd"
  reasons=$(grep -rhoE 'not read\*? \(([^)]*)\)' "$WIKI" --include='*.md' 2>/dev/null \
            | sed -E 's/.*\(([^)]*)\).*/\1/' | sed -E 's/[,;].*$//' | sort | uniq -c | sort -rn)
  if [ -n "$reasons" ]; then printf '  not-read reasons (incl. timed-out = unreadable this pass):\n'
    printf '%s\n' "$reasons" | sed 's/^/    /'
  fi
else
  printf '  (no wiki/ yet)\n'
fi

# --- wiki pages --------------------------------------------------------------
printf '\nWIKI PAGES\n'; rule
if [ -d "$WIKI" ]; then
  npages=$(find "$WIKI" -name '*.md' | wc -l | tr -d ' ')
  printf '  total           %s\n' "$npages"
  printf '  by type         '
  grep -rhoE '^type: *[a-z]+' "$WIKI" --include='*.md' 2>/dev/null | awk '{print $2}' \
    | sort | uniq -c | sort -rn | awk '{printf "%s:%s  ", $2, $1}'; printf '\n'
  printf '  by privilege    '
  grep -rhoE '^privilege: *[a-z-]+' "$WIKI" --include='*.md' 2>/dev/null | awk '{print $2}' \
    | sort | uniq -c | sort -rn | awk '{printf "%s:%s  ", $2, $1}'; printf '\n'
  rev=$(grep -rl '\[!review\]' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
  revn=$(grep -rho '\[!review\]' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
  printf '  open [!review]   %s flag(s) across %s page(s)\n' "$revn" "$rev"
  qz=$(grep -rlE '^relevance: *off-topic' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
  [ "${qz:-0}" -gt 0 ] && printf '  quarantined     %s page(s) (relevance: off-topic; excluded from index/publish)\n' "$qz"
  hm=$(grep -rlE '^maintained_by: *human' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
  [ "${hm:-0}" -gt 0 ] && printf '  human-maintained %s page(s) (owner-authored; agent never rewrites them)\n' "$hm"
  oq=$(grep -rlE '^origin: *query' "$WIKI" --include='*.md' 2>/dev/null | wc -l | tr -d ' ')
  if [ "${oq:-0}" -gt 0 ]; then
    oqv=0; oqu=0
    for qf in $(grep -rlE '^origin: *query' "$WIKI" --include='*.md' 2>/dev/null); do
      if grep -qE '^verified: *[0-9]' "$qf"; then oqv=$((oqv+1)); else oqu=$((oqu+1)); fi
    done
    printf '  query-filed     %s page(s) (origin: query; %s verified, %s unverified)\n' "$oq" "$oqv" "$oqu"
  fi
else
  printf '  (none yet)\n'
fi

# --- sensitivity (sidecar; Phase 1 of routing) -------------------------------
printf '\nSENSITIVITY (.ingest/sensitivity.tsv)\n'; rule
if have "$SENS"; then
  awk -F'\t' '$1 ~ /^#/ || $1=="" {next}
    {n++; t[$2]++}
    END{
      printf "  classified     %d items\n", n
      printf "  personal-sensitive %d  business-sensitive %d  default %d\n", t["personal-sensitive"]+0, t["business-sensitive"]+0, t["default"]+0
    }' "$SENS"
else
  printf '  (none yet — run ./scripts/classify)\n'
fi

# --- relevance (sidecar; Phase 2 of relevance) -------------------------------
printf '\nRELEVANCE (.ingest/relevance.tsv)\n'; rule
if have "$RELEVANCE"; then
  awk -F'\t' '$1 ~ /^#/ || $1=="" {next}
    {n++; t[$2]++}
    END{
      printf "  triaged        %d items\n", n
      printf "  relevant %d  off-charter %d  junk %d  misfiled %d  unsure %d\n", \
        t["relevant"]+0, t["off-charter"]+0, t["junk"]+0, t["misfiled"]+0, t["unsure"]+0
      p=(t["off-charter"]+0)+(t["junk"]+0)+(t["misfiled"]+0)+(t["unsure"]+0)
      if(p>0) printf "  %d parked (not deep-read); see pending.md Relevance review\n", p
    }' "$RELEVANCE"
else
  printf '  (none yet — the map pass writes it; see docs/relevance.md)\n'
fi

# --- verification (qa.tsv) ---------------------------------------------------
printf '\nVERIFICATION (.ingest/qa.tsv)\n'; rule
npages=$([ -d "$WIKI" ] && find "$WIKI" -name '*.md' | wc -l | tr -d ' ' || echo 0)
if have "$QA"; then
  awk -F'\t' -v np="$npages" '
    $1 ~ /^#/ || $1=="" {next}
    {aud++; sct+=$4; sup+=$5; if($2=="verified")v++; else if($2=="flagged")fl++}
    END{
      printf "  audited        %d of %d pages\n", aud, np
      printf "  verified %d  flagged %d  unverified %d\n", v+0, fl+0, np-aud
      if(np>0) printf "  %% verified     %d%%\n", int((v+0)*100/np)
      if(sct>0) printf "  claims         %d checked, %d supported (%d%%)\n", sct, sup, int(sup*100/sct)
    }' "$QA"
else
  printf '  (none yet — run ./scripts/ingest --verify)\n'
fi

# --- queries (prominence signal) --------------------------------------------
printf '\nMOST QUERIED (.ingest/queries.tsv)\n'; rule
if have "$QUERIES"; then
  awk -F'\t' '$1 ~ /^#/ || $1=="" {next}
    {n++; c[$2]++; if($1>last[$2]) last[$2]=$1}
    END{ np=0; for(p in c) np++
         printf "  logged         %d page-hit(s) across %d page(s)\n", n, np }' "$QUERIES"
  printf '  most queried:\n'
  awk -F'\t' '$1 ~ /^#/ || $1=="" {next}
    {c[$2]++; if($1>last[$2]) last[$2]=$1}
    END{ for(p in c) printf "%d\t%s\t%s\n", c[p], p, last[p] }' "$QUERIES" \
    | sort -rn | head -10 \
    | awk -F'\t' '{printf "    %4d  %-28s (last asked %s)\n", $1, $2, $3}'
else
  printf '  (none yet — answered queries log page hits here)\n'
fi

# --- demand (query-driven depth signal) -------------------------------------
printf '\nDEMANDED (.ingest/demand.tsv)\n'; rule
if have "$DEMAND"; then
  covf="$COVERAGE"; [ -f "$covf" ] || covf=/dev/null
  awk -F'\t' '
    FNR==NR { if($1!~/^#/ && $1!="") cov[$1]=$3; next }
    $1~/^#/ || $1=="" {next}
    { n++; c[$2]++ }
    END{ ns=0; for(s in c) ns++; printf "  logged         %d demand(s) across %d source(s)\n", n, ns }
  ' "$covf" "$DEMAND"
  printf '  most demanded:\n'
  awk -F'\t' '
    FNR==NR { if($1!~/^#/ && $1!="") cov[$1]=$3; next }
    $1~/^#/ || $1=="" {next}
    { c[$2]++; if($1>last[$2]) last[$2]=$1 }
    END{ for(s in c){ st=(s in cov)?cov[s]:"?"; printf "%d\t%s\t%s\t%s\n", c[s], s, st, last[s] } }
  ' "$covf" "$DEMAND" \
    | sort -rn | head -10 \
    | awk -F'\t' '{printf "    %4d  %-28s [%s]  (last asked %s)\n", $1, $2, $3, $4}'
else
  printf '  (none yet — a query logs a source here when its data is unread)\n'
fi

# --- cost --------------------------------------------------------------------
printf '\nCOST (.ingest/cost.tsv)\n'; rule
if have "$COST"; then
  awk -F'\t' '
    $1 ~ /^#/ || $1=="" {next}
    {tot+=$2; n++; mode[$6]+=$2; moden[$6]++; model[($7==""?"(unrecorded)":$7)]+=$2; modeln[($7==""?"(unrecorded)":$7)]++}
    END{
      printf "  total spend     $%.2f across %d pass(es)\n", tot, n
      printf "  by pass mode:\n"; for(k in mode) printf "    %-12s $%.2f  (%d)\n", k, mode[k], moden[k]
      printf "  by model:\n";     for(k in model) printf "    %-22s $%.2f  (%d)\n", k, model[k], modeln[k]
    }' "$COST"
else
  printf '  (no runs yet)\n'
fi

# --- optional: resolve coverage paths on disk (missing/unreadable) -----------
if [ "$CHECK" -eq 1 ] && have "$COVERAGE"; then
  printf '\nDISK CHECK (--check)\n'; rule
  miss=0; ok=0
  while IFS=$'\t' read -r path _v _s _p _l _f _n; do
    case "${path:-}" in ''|'#'*) continue;; esac
    if [ -e "$RAW/$path" ] || [ -L "$RAW/$path" ]; then ok=$((ok+1)); else miss=$((miss+1)); fi
  done < <(grep -v '^#' "$COVERAGE")
  printf '  resolvable      %d\n  missing/unreadable on disk  %d\n' "$ok" "$miss"
  [ "$miss" -gt 0 ] && printf '  (note: in a container, OneDrive paths will all show missing — run on your Mac)\n'
fi

printf '\n'
